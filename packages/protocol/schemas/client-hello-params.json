{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ClientHelloParams",
  "description": "Params for the client.hello request declaring protocol version and domain subscriptions",
  "type": "object",
  "properties": {
    "protocol": {
      "type": "object",
      "properties": {
        "version": { "type": "integer", "minimum": 1 }
      },
      "required": ["version"],
      "additionalProperties": false
    },
    "client": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" }
      },
      "required": ["name", "version"],
      "additionalProperties": false
    },
    "enable": {
      "type": "array",
      "items": { "type": "string" }
    },
    "subscribe": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": true
      }
    }
  },
  "required": ["protocol", "client"],
  "additionalProperties": false
}
