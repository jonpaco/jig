{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ServerHelloParams",
  "description": "Params for the server.hello notification sent immediately on WebSocket connect",
  "type": "object",
  "properties": {
    "protocol": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "integer", "minimum": 1 },
        "min": { "type": "integer", "minimum": 1 },
        "max": { "type": "integer", "minimum": 1 }
      },
      "required": ["name", "version", "min", "max"],
      "additionalProperties": false
    },
    "server": {
      "type": "string",
      "description": "Jig server version (semver)"
    },
    "app": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "bundleId": { "type": "string" },
        "platform": { "type": "string", "enum": ["ios", "android"] },
        "rn": { "type": "string" },
        "expo": { "type": "string" }
      },
      "required": ["name", "bundleId", "platform", "rn"],
      "additionalProperties": false
    },
    "commands": {
      "type": "array",
      "items": { "type": "string" }
    },
    "domains": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "required": ["protocol", "server", "app", "commands", "domains"],
  "additionalProperties": false
}
