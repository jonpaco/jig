{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ScreenshotParams",
  "description": "Params for the jig.screenshot command",
  "type": "object",
  "properties": {
    "format": {
      "type": "string",
      "enum": ["png", "jpeg"],
      "default": "png",
      "description": "Image encoding format"
    },
    "quality": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100,
      "default": 80,
      "description": "JPEG compression quality (ignored for PNG)"
    }
  },
  "additionalProperties": false
}
