{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "HandshakeErrorData",
  "description": "Error data attached to handshake error responses (e.g., version mismatch)",
  "type": "object",
  "properties": {
    "supported": {
      "type": "object",
      "properties": {
        "min": { "type": "integer", "minimum": 1 },
        "max": { "type": "integer", "minimum": 1 }
      },
      "required": ["min", "max"],
      "additionalProperties": false
    }
  },
  "required": ["supported"],
  "additionalProperties": false
}
